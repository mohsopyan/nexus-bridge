# ==============================================================================
# NEXUS-BRIDGE ENVIRONMENT VARIABLES EXAMPLE
# Salin file ini menjadi .env dan isi dengan nilai yang sesuai.
# ==============================================================================

# --- GATEWAY SERVICE (Node.js) ---
PORT=3000
NODE_ENV=development
JWT_SECRET=your_super_secret_jwt_key_here

# --- DATABASE (PostgreSQL) ---
# Jika menggunakan Docker Compose, gunakan nama service 'db' sebagai host
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password
POSTGRES_DB=your_db
DATABASE_URL="postgresql://postgres:your_password@db:5432/nexus_db?schema=public"

# --- AI ENGINE SERVICE (Python) ---
# URL untuk Gateway memanggil Engine (Gunakan 'engine-service' jika di Docker)
PYTHON_ENGINE_URL=http://engine-service:8000

# --- GEMINI AI CONFIGURATION ---
# Dapatkan API Key di: https://aistudio.google.com/
GEMINI_API_KEY=AIzaSy...your_gemini_api_key_here