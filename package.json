{
  "name": "nexus-bridge-root",
  "version": "1.0.0",
  "description": "Hybrid Backend Architecture with Node.js & Python AI",
  "private": true,
  "scripts": {
    "install:all": "npm install && cd gateway-service && npm install",
    "dev:gateway": "cd gateway-service && npm run dev",
    "dev:engine": "cd engine-service && venv\\Scripts\\activate && uvicorn main:app --reload",
    "dev": "concurrently \"npm run dev:gateway\" \"npm run dev:engine\""
  },
  "devDependencies": {
    "concurrently": "^8.0.0"
  },
  "dependencies": {
    "cors": "^2.8.6"
  }
}
